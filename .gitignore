# ─── Secrets / environment ───────────────────────────────────────────────────
.env
.env.*
!.env.example
**/supabase_local.json
supabase/supabase_local.json
config/supabase_local.json
dart_defines.json
dart_defines.*.json
*.pem
*.key
*.keystore
*.jks
*.p12
*.mobileprovision
*.p8
*.pfx
*.cer
secrets/
supabase/.temp/
supabase/.branches/

# Prebuilt FFmpeg — يُولَّد محلياً (scripts/fetch_ffmpeg_bundles.*). يُبقى .gitkeep فقط.
bundled_ffmpeg/windows/*
!bundled_ffmpeg/windows/.gitkeep
bundled_ffmpeg/linux/*
!bundled_ffmpeg/linux/.gitkeep

# حزم الأدوات كبيرة الحجم (أوفلاين) تُبنى محلياً أو في CI
assets/bundled_ffmpeg/embed_*.zip
assets/bundled_ffmpeg/windows/ffmpeg.exe
assets/bundled_ffmpeg/linux/ffmpeg
assets/bundled_ytdlp/windows/yt-dlp.exe
assets/bundled_ytdlp/linux/yt-dlp

# Android FFmpeg-Kit: downloaded AAR (POM is committed)
android/ffmpeg-kit-repo/com/arthenica/ffmpeg-kit-min-gpl/6.0-2/ffmpeg-kit-min-gpl-6.0-2.aar
android/ffmpeg-kit-repo/com/arthenica/ffmpeg-kit-full-gpl/6.0-2/ffmpeg-kit-full-gpl-6.0-2.aar

