{
  "manifest_version": 3,
  "name": "Dark Downloader Bridge",
  "version": "2.1.0",
  "description": "Send media directly to Dark Downloader with one click. Automatically detects videos on supported platforms.",
  "permissions": ["activeTab", "tabs", "storage", "contextMenus"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.tiktok.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.facebook.com/*",
        "*://*.vimeo.com/*",
        "*://*.dailymotion.com/*",
        "*://*.soundcloud.com/*",
        "*://*.reddit.com/*",
        "*://*.twitch.tv/*",
        "*://*.pinterest.com/*",
        "*://*.rumble.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["http://localhost:3030/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
