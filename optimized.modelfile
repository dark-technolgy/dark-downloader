FROM qwen3-27b:latest
# تقليل السياق قليلاً لضمان بقاء الموديل داخل ذاكرة الكرت 16GB
PARAMETER num_ctx 8192
# استخدام كافة طبقات الموديل على الـ GPU
PARAMETER num_gpu 99
# استخدام كافة خيوط المعالج الـ 20
PARAMETER num_thread 20
PARAMETER temperature 0.3
SYSTEM """
You are a high-speed AI running on a dedicated RTX 4080. Respond instantly.
"""
