# Cloudflare API Token for the SOURCE account (keenx22@gmail.com)
# Permissions needed: Zone.Zone Read, Zone.DNS Read
CF_SOURCE_TOKEN=your_source_api_token

# Cloudflare API Token for the DESTINATION account (dark.ai.technology@gmail.com)
# Permissions needed: Zone.Zone Write, Zone.DNS Write
CF_DEST_TOKEN=your_destination_api_token

# Account ID of the DESTINATION account
# You can find this in the Cloudflare Dashboard URL or Overview page
CF_DEST_ACCOUNT_ID=your_destination_account_id
