{
  "db": {
    "tables": [
      { "name": "profiles", "description": "User profiles (optional; only for cloud sync)" },
      { "name": "downloads", "description": "Cloud-synced download history" },
      { "name": "browser_history", "description": "Cloud-synced browser history" },
      { "name": "bookmarks", "description": "Cloud-synced bookmarks" },
      { "name": "adblock_whitelist", "description": "User adblock whitelist entries" },
      { "name": "audit_logs", "description": "Audit trail for admin actions" },
      { "name": "remote_config", "description": "App-wide runtime configuration" },
      { "name": "extractor_rules", "description": "Signed extractor rule packs (hot-updated)" },
      { "name": "extractor_failures", "description": "Anonymous extractor failure telemetry (opt-in)" }
    ]
  },
  "functions": [
    {
      "name": "ai-media-helper",
      "description": "AI helper for media extraction hints"
    },
    {
      "name": "get-extractor-rules",
      "description": "Serve latest signed extractor rule packs to clients"
    },
    {
      "name": "report-extractor-failure",
      "description": "Anonymous extractor failure reporter (opt-in telemetry)"
    }
  ],
  "auth": {
    "providers": ["email", "google", "apple"],
    "enableEmailConfirmation": true,
    "enablePhoneConfirmation": false
  }
}
